# ============================================
# DUO OS — Variables de entorno (FRONTEND)
# Copia este archivo como .env y rellena los valores.
# En Vercel: Settings -> Environment Variables (mismos nombres).
# ============================================

# Supabase (Settings -> API en tu proyecto de Supabase)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Calendar OAuth (opcional, Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=https://duo-os.vercel.app/auth/google/callback

# NOTA: La clave de Gemini NO va aquí (sería visible en el navegador).
# Se guarda como secreto SERVER-SIDE en Supabase con el nombre GEMINI_API_KEY
# (Supabase -> Edge Functions -> Secrets). La usa la función gemini-chat.
# Lo mismo para RESEND_API_KEY (motor de email).
